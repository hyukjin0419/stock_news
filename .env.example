# Supabase — Project Settings > API 에서 복사
SUPABASE_URL=https://your-project.supabase.co
# Secret 키 (RLS 우회). 절대 프론트/깃에 올리지 말 것.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx

# 국내 뉴스 — 네이버 개발자센터 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 해외 뉴스 — Finnhub (무료)
FINNHUB_API_KEY=

# 요약 LLM — Claude
ANTHROPIC_API_KEY=

# Gmail 발송 (앱 비밀번호)
GMAIL_USER=
GMAIL_APP_PASSWORD=
